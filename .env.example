# ─────────────────────────────────────────────────────────────────────────────
# Gnaver environment. Copy this file to `.env` and fill in your keys.
# `.env` is git-ignored — never commit real keys.
# Everything works WITHOUT keys (realistic mock data); keys upgrade to live data.
# ─────────────────────────────────────────────────────────────────────────────

# Google Maps Platform — enable: Places API (New), Directions API, Geocoding API.
# Restrict this key to your iOS bundle id (com.ariomoniri.gnaver).
EXPO_PUBLIC_GOOGLE_API_KEY=

# Weather — optional. Gnaver uses free Open-Meteo by default (no key needed).
# Only set this if you want to use OpenWeather instead.
EXPO_PUBLIC_WEATHER_API_KEY=

# LLM for the conversational taste / food recommender.
# Provider: "anthropic" (default) or "openai".
EXPO_PUBLIC_LLM_PROVIDER=anthropic
EXPO_PUBLIC_LLM_API_KEY=
EXPO_PUBLIC_LLM_MODEL=claude-haiku-4-5-20251001

# Native Google Maps SDK key (Android map rendering only; iOS uses Apple Maps).
GOOGLE_MAPS_ANDROID_KEY=

# EAS / App Store automation (filled by `eas init`).
EAS_PROJECT_ID=
